// AccelSim HBMNet Topology
// Models L2-HBM path: hit (Xbar→HBM) vs miss (Xbar→MC→HBM)
topology = hbmnet_accelsim;

// Topology: P Xbars in a chain, H HBM stacks per side per Xbar
// Total HBM stacks K = P * H * 2
// Derived: num_sms = sm_per_xbar * P,  num_l2_slices = l2_per_hbm * K
sm_per_xbar = 74;
num_xbars = 2;
hbm_per_side = 2;
l2_per_hbm = 32;
// P=2, H=2 → K=8, num_sms=148, num_l2=256
l2_interleave = 0;

// Routing
// routing_function must always be "hybrid" — hit/miss split is decided at injection
// based on baseline_ratio (hit rate).
// Hit flits: Xbar → HBM (direct)
// Miss flits: Xbar → MC → (MC fabric if available) → HBM, routed via hybrid_routing.
routing_function = hybrid;

// Miss-path routing sub-function:
//   baseline          deterministic chain routing (no MC-MC fabric)
//   min_adaptive      least-congested minimal port selection
//   min_oblivious     random minimal port selection
//   near_min_adaptive near-minimal with congestion-aware detour (+1/+2 hop)
//   near_min_random   near-minimal with random detour selection (+1/+2 hop)
//   fixed_min  deterministic min, MC-MC fabric preferred over Xbar chain
//   ugal              adaptive non-minimal via intermediate
//   valiant           oblivious non-minimal via random intermediate
hybrid_routing = fixed_min;

is_fabric = 1;
ugal_threshold = 50;
ugal_intm_select = 0;

// Hit rate: fraction of flits that take the hit path (Xbar→HBM direct)
// 0.0 = all miss (all go through MC), 1.0 = all hit (no MC involvement)
baseline_ratio = 0.0;

// Near-min k budget: max total non-min hops allowed per packet
//   k=1: allows one +1 hop (dist stays same) — cannot do +2 hop
//   k=2: allows one +2 hop (dist increases by 1, 2x penalty) OR one +1 hop
//        (+1 hop twice is blocked by u-turn prevention in practice)
near_min_k = 1;

// Near-min penalty multiplier: scales the latency penalty for near-min directions.
// 0.0 = no penalty (always pick least congested), 1.0 = default, >1.0 = more conservative
// +1 hop cost: sat + penalty * lat_norm * (1 + sat)
// +2 hop cost: sat + 2 * penalty * lat_norm * (1 + sat)
near_min_penalty = 1.0;

// Near-min strict mode: controls where non-min hops are allowed
//   0 = relieved: non-min blocked only when cur partition is outside the natural
//                 routing range [min(src_part,dest_part), max(src_part,dest_part)].
//                 Non-min IS allowed in dest partition. Applies to Xbar and MC.
//   1 = strict:   non-min blocked once packet enters the dest partition
near_min_strict = 0;

// Near-min remote-only: restrict non-min hops to cross-partition (remote) accesses only
//   0 = allow non-min for both local and remote accesses (default)
//   1 = disable non-min for same-partition (local) accesses
near_min_remote_only = 1;

inject_latency = 50;
eject_latency = 50;

// Link latencies (cycles)
xbar_xbar_latency = 150;
xbar_hbm_latency = 30;    // hit path: Xbar ↔ HBM
xbar_mc_latency = 150;
mc_hbm_latency = 100;
mc_mc_latency = 150;

// Link bandwidths (parallel ports per link pair)
xbar_xbar_bandwidth = 28;
xbar_hbm_bandwidth = 8;   // hit path
xbar_mc_bandwidth = 8;
mc_hbm_bandwidth = 12;
mc_mc_bandwidth = 10;

// Flow control
num_vcs = 4;
vc_buf_size = 128;
wait_for_tail_credit = 0;

// Router architecture
vc_allocator = islip;
sw_allocator = islip;
alloc_iters  = 1;

credit_delay   = 0;
routing_delay  = 0;
vc_alloc_delay = 1;
sw_alloc_delay = 1;

input_speedup     = 1;
output_speedup    = 1;
internal_speedup  = 2.0;
// HBM router internal speedup override (0.0 = use global internal_speedup).
// Set > 0 to give HBM routers a faster crossbar so mc_hbm_bandwidth is the
// true TSV bottleneck rather than the router crossbar.
hbm_internal_speedup = 10.0;

// Traffic
// only generate SM node -> L2 node random traffic
traffic = gpu;
remote_only = 1;
injection_process = gpu_bernoulli;
packet_size = 1;

use_read_write = 0;

latency_thres = 500000.0;

// Simulation
sim_type = moe_accelsim;
// sim_type = moe_accelsim;
injection_rate = 0.01;
flit_width_bytes = 40;
traffic_matrix_file = ./examples/remote_symmetric_4MiB.matrix;

read_request_begin_vc = 0;
read_request_end_vc = 3;
read_reply_begin_vc = 0;
read_reply_end_vc = 3;
write_request_begin_vc = 0;
write_request_end_vc = 3;
write_reply_begin_vc = 0;
write_reply_begin_vc = 3;

read_request_size = 1;
read_reply_size = 1;
write_request_size = 1;
write_reply_size = 1;
moe_total_mb = 4.0;